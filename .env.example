SPRING_DATASOURCE_URL=jdbc:mysql://your-rds-endpoint:3306/dodo?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=todo_user
SPRING_DATASOURCE_PASSWORD=change-me

JWT_SECRET=change-me-to-at-least-32-bytes-secret
JWT_ACCESS_TOKEN_EXPIRATION_SECONDS=1800
JWT_REFRESH_TOKEN_EXPIRATION_SECONDS=604800

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI={baseUrl}/login/oauth2/code/{registrationId}
